# 企业微信配置
SENDKEY=your_sendkey
WECOM_CID=your_corpid
WECOM_SECRET=your_secret
WECOM_AID=your_agentid
WECOM_TOUID=@all

# Bark（可选）
BARK_URL=https://api.day.app/your_key

# 钉钉机器人（可选）
DINGTALK_TOKEN=your_token
DINGTALK_SECRET=your_secret

# 飞书机器人（可选）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_hook

# Telegram Bot（可选）
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Server酱（可选）
SERVERCHAN_KEY=your_key

# PushPlus（可选）
PUSHPLUS_TOKEN=your_token

# 缓存配置
CACHE_TYPE=memory
# CACHE_TYPE=redis

# Redis 配置（可选）
REDIS_STAT=OFF
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
